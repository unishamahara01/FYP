{
  "buildCommand": "REACT_APP_API_URL=https://meditrust-backend-48uj.onrender.com/api npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "build": {
    "env": {
      "REACT_APP_API_URL": "https://meditrust-backend-48uj.onrender.com/api"
    }
  },
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
