# Backend API URL
REACT_APP_API_URL=http://localhost:3001

# ML Backend API URL (Optional - for AI features)
REACT_APP_ML_API_URL=http://localhost:5000

# Google OAuth (Optional - for Google Sign-In)
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-here

# Instructions:
# 1. Copy this file to .env
# 2. Update URLs if deploying to production
# 3. For Google Sign-In, get credentials from: https://console.cloud.google.com/
# 4. Never commit the .env file to Git
