# Server Configuration
PORT=3001
NODE_ENV=development
SESSION_SECRET=your-session-secret-change-this

# Public URLs
FRONTEND_URL=http://localhost:3000
SERVER_URL=http://localhost:3001

# CORS Allowlist (comma-separated)
# Example: https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=

# MongoDB Database
MONGODB_URI=mongodb://localhost:27017/meditrust

# JWT Secret (Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-specific-password

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# AI Backend (Optional)
AI_BACKEND_URL=http://localhost:5001
START_AI_BACKEND=false

# OpenRouter (Optional - AI Chatbot)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=MediTrust

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit the .env file to Git
